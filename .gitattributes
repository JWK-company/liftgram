# 크로스플랫폼 일관성 — 모든 텍스트는 UTF-8 · LF 고정.
# (Windows/Git Bash 에서 autocrlf 로 CRLF 가 섞여 셸 스크립트가 깨지는 것을 방지)
* text=auto eol=lf

# 실행/스크립트는 반드시 LF (CRLF 면 bash 가 $'\r' 로 깨짐)
*.sh      text eol=lf
*.py      text eol=lf
Makefile  text eol=lf

# 문서/설정도 LF 통일 (한글은 모두 UTF-8)
*.md      text eol=lf
*.json    text eol=lf
*.html    text eol=lf
*.env.example text eol=lf

# 바이너리(향후 이미지 등)는 변환 금지
*.png binary
*.jpg binary
*.gif binary
*.ico binary
