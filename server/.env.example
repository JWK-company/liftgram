# 서버
PORT=3000
NODE_ENV=development

# PostgreSQL — 로컬 PG16(5432) 기준. DB=liftgram, 롤=본인(예: wbi).
# docker compose 사용 시: postgresql://liftgram:liftgram@localhost:5433/liftgram?schema=public
DATABASE_URL="postgresql://wbi:wbi@127.0.0.1:5432/liftgram?schema=public"

# JWT (로컬 인증 토대 — ADR-018: 추후 매니지드 인증으로 어댑터 교체)
# 프로덕션(NODE_ENV=production)에선 'dev-change-me'면 부팅 실패 — 강력한 랜덤값 필수.
JWT_SECRET="dev-change-me"
JWT_EXPIRES_IN="15m"

# ── 역할 부트스트랩 (선택) — 시작 시 지정 계정 role 멱등 시딩. auth/role-bootstrap.service.ts ──
# 첫 admin 지정(치킨-에그 해결) + 팀원 coworker 지정. 해당 계정은 먼저 가입돼 있어야 함.
# 이메일은 소문자 정규화되어 저장되므로 소문자로 기입. 이후 상시 변경은 PATCH /users/:id/role(admin).
# ADMIN_EMAIL="admin@example.com"
# COWORKER_EMAILS="coworker1@example.com,coworker2@example.com"

# ── 배포(프로덕션)용 — 로컬은 없어도 됨 ──────────────────────────────
# 프론트(웹앱) 주소만 허용하려면(권장). 없으면 모든 출처 허용(dev/POC).
# CORS_ORIGINS="https://liftgram-web.example.com"
# 미디어(사진) 저장 어댑터. local=서버 디스크(무료 호스팅은 재배포 시 초기화).
# r2/s3=클라우드(재배포에도 사진 유지). Cloudflare R2 무료 10GB 권장.
STORAGE_PROVIDER="local"
# MEDIA_DIR="uploads"
# ── 클라우드 사진 저장(STORAGE_PROVIDER=r2 일 때만) ──────────────────
# Cloudflare R2: 버킷 생성 → R2 API 토큰 발급(Access Key/Secret) → 엔드포인트 복사.
# S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# S3_BUCKET="liftgram-media"
# S3_REGION="auto"                # R2는 auto
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# 푸시 발송 어댑터. noop=끔 / auto=VAPID 있으면 웹푸시. POC는 noop 권장.
PUSH_PROVIDER="noop"
# 웹푸시 쓰려면(선택): npx web-push generate-vapid-keys 로 생성해 채움.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:you@example.com"

# ── 개발 피드백 → PLM 아이디어보드 (feedback 모듈, coworker/admin 전용 탭) ──────
# 앱의 피드백 탭이 자연어 문제·개선을 PLM(plm-hub) 아이디어보드로 등록/조회할 때 서버가 사용.
# 토큰 미설정이면 피드백 API가 503(기능 비활성). 토큰은 절대 클라이언트에 노출 금지 — 서버 전용.
# 운영 배포 시 owner가 아닌 editor 범위 토큰 권장(plm-hub 대시보드에서 발급).
# PLM_API_URL="https://jwk-plm.shoi.ch"
# PLM_PROJECT="liftgram"
# PLM_API_TOKEN=""

# ── 착용장비 제휴(gear 모듈 · SRS-039 · ADR-027) ────────────────────────────────
# GET /api/gear/config 가 앱에 내려주는 값. 서버 전용 — EXPO_PUBLIC_* 로 앱에 넣지 말 것
# (react-native-web 번들에 평문으로 굳어 회수 불가 + 링크 교체에 앱 재배포가 필요해진다).
#
# ⚠ 최종승인 전에는 GEAR_AFFILIATE_ENABLED 를 true 로 두지 않는다.
#   쿠팡 파트너스 미디어(모바일 앱) 등록과 최종승인이 끝나기 전에 광고를 노출하면
#   '미등록 매체 광고 노출'로 A등급 제재(수익 몰수·계정 해지) 대상이다.
#   두 값 모두 미설정인 상태가 곧 Phase 0 정상 상태이며, 앱은 추적 0개 검색 URL로 폴백한다.
#
# 'true' 문자열과 정확히 일치할 때만 활성. 'yes'·'1'·'TRUE' 는 전부 비활성으로 처리된다.
# GEAR_AFFILIATE_ENABLED="false"
#
# 카테고리(8종)→딥링크 JSON 한 줄. 값은 파트너스 웹 링크 생성기 또는 Deeplink API로 사람이
# 사전 생성한 딥링크(link.coupang.com/a/…)여야 하며, 서버·앱 어느 쪽도 이 문자열을 가공하지 않는다
# (운영정책 4.1 1) 링크 조작 = A등급). 원본 URL은 반드시 '카테고리 검색 결과 페이지'로 —
# 상품 상세(/vp/products/…) 딥링크는 브랜드·모델 미특정 원칙(ADR-027 D5)을 링크 계층에서 무력화한다.
# 8종 밖의 키는 서버가 화이트리스트로 걸러 응답에 싣지 않는다.
# 카테고리: wristWrap · strap · belt · kneeSleeve · gloves · shoes · chalk · armSleeve
# 활성화 직후 체크: 8종 전부가 GET /api/gear/stats 에서 kind="deeplink" 로 잡히는지 1회 확인.
# 한 종이라도 "search" 로 남으면 그 카테고리 딥링크가 오기입된 것이다(수수료 0원인데 고지 라벨만 노출).
# GEAR_AFFILIATE_LINKS='{"wristWrap":"https://link.coupang.com/a/XXXX","belt":"https://link.coupang.com/a/YYYY"}'
