# 서버
PORT=3000
NODE_ENV=development

# PostgreSQL — 로컬 PG16(5432) 기준. DB=liftgram, 롤=본인(예: wbi).
# docker compose 사용 시: postgresql://liftgram:liftgram@localhost:5433/liftgram?schema=public
DATABASE_URL="postgresql://wbi:wbi@127.0.0.1:5432/liftgram?schema=public"

# JWT (로컬 인증 토대 — ADR-018: 추후 매니지드 인증으로 어댑터 교체)
# 프로덕션(NODE_ENV=production)에선 'dev-change-me'면 부팅 실패 — 강력한 랜덤값 필수.
JWT_SECRET="dev-change-me"
JWT_EXPIRES_IN="15m"

# ── 배포(프로덕션)용 — 로컬은 없어도 됨 ──────────────────────────────
# 프론트(웹앱) 주소만 허용하려면(권장). 없으면 모든 출처 허용(dev/POC).
# CORS_ORIGINS="https://liftgram-web.example.com"
# 미디어(사진) 저장 어댑터. local=서버 디스크(무료 호스팅은 재배포 시 초기화).
STORAGE_PROVIDER="local"
# MEDIA_DIR="uploads"
# 푸시 발송 어댑터. noop=끔 / auto=VAPID 있으면 웹푸시. POC는 noop 권장.
PUSH_PROVIDER="noop"
# 웹푸시 쓰려면(선택): npx web-push generate-vapid-keys 로 생성해 채움.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:you@example.com"
