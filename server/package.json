    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.5.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.20.0",
    "typescript": "^5.6.2"
  }
