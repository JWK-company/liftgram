{
  "name": "health-practice-server",
  "version": "0.1.0",
  "description": "헬스앱 백엔드 — Node.js/TS 모듈러 모놀리스 (ADR-018) + PostgreSQL. 계정·인증·동기 토대(SRS-006/ADR-002/SAD-004).",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
