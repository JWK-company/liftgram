// 헬스앱 백엔드 스키마 — 계정·인증·동기 + 소셜(팔로우·포스트) + 미디어. @plm SRS-006 @plm SRS-018 @plm SRS-007 @plm SRS-019
// 동기 모델은 오프라인-우선 last-write-wins(ADR-002·SAD-004). Phase 0 도메인(운동·루틴·세션)은
// 서버에선 불투명 JSON(SyncRecord.payload)으로 보관·동기(스키마 권위=클라이언트 WatermelonDB), 추후 정규화.
// 소셜(Follow·Post)·미디어(MediaAsset)는 크로스유저 공유 데이터 → 서버 관계형 권위 + REST(온라인). 옵트인 공개 레이어(ADR-014·SAD-011/012).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String?        @unique
  displayName   String?
  avatarUrl     String? // 프로필 아바타(업로드 미디어 URL)
  passwordHash  String? // 로컬 인증 토대 — 매니지드 전환 시 null (ADR-018)
  authProvider  String         @default("local") // local|email|google|apple|managed
  role          String         @default("user") // user|moderator|admin (모더레이션 권한 · ADR-017)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  devices       Device[]
  refreshTokens RefreshToken[]
  syncRecords   SyncRecord[]
  following     Follow[]       @relation("following") // 내가 팔로우하는 관계
  followers     Follow[]       @relation("followers") // 나를 팔로우하는 관계
  posts         Post[]
  mediaAssets   MediaAsset[]
  stories       Story[]
  conversations ConversationParticipant[]
  messages      Message[]
  postLikes         PostLike[]
  comments          Comment[]
  notifications     Notification[] @relation("notifications")
  notificationsSent Notification[] @relation("notificationsActor")
  reports           Report[]       @relation("reporter")
  reviewedReports   Report[]       @relation("reviewer")
  pushTokens        PushToken[]
  blocking          Block[]        @relation("blocker") // 내가 차단한
  blockedBy         Block[]        @relation("blocked") // 나를 차단한
}

// 사용자 차단 (SRS-018). 차단=상호 불가시 + 상호작용 차단. 팔로우는 차단 시 해제.
model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Device {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String?
  platform   String? // web|ios|android
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// 오프라인-우선 동기 레코드 (ADR-002 · SAD-004). 클라이언트 push/pull 대상.
model SyncRecord {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection String // exercises|routines|workouts|...
  recordId   String // 클라이언트 레코드 id
  payload    Json
  version    Int      @default(1)
  deleted    Boolean  @default(false)
  createdAt  DateTime @default(now()) // created/updated 구분(WatermelonDB pull)
  updatedAt  DateTime @updatedAt

  @@unique([userId, collection, recordId])
  @@index([userId, collection, updatedAt])
}

// 소셜 그래프 (SRS-018 · SAD-011). 방향 = follower → followee.
model Follow {
  id         String   @id @default(uuid())
  followerId String
  followeeId String
  follower   User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User     @relation("followers", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, followeeId])
  @@index([followeeId])
}

// 피드 게시물 (SRS-007 · SAD-011). 텍스트/운동 + 이미지(data.mediaUrl). 스토리·영상은 후속(SAD-012).
model Post {
  id         String   @id @default(uuid())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind       String   @default("text") // text|workout|image
  caption    String?
  data       Json? // 운동 요약·이미지 URL 등 부가 데이터(불투명).
  visibility String   @default("public") // public|followers|private
  moderationStatus String @default("approved") // approved|pending|removed (ADR-017)
  removedAt     DateTime?
  removedReason String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  likes      PostLike[]
  comments   Comment[]
  hashtags   PostHashtag[]

  @@index([authorId, createdAt])
  @@index([moderationStatus])
  @@index([createdAt])
  @@index([createdAt, id]) // 키셋 커서 페이지네이션(무한스크롤)
}

// 해시태그 인덱스 (SRS-018). 포스트 캡션의 #태그 추출·저장 → 태그별 조회·트렌딩.
model PostHashtag {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       String // 소문자 정규화
  createdAt DateTime @default(now())

  @@unique([postId, tag])
  @@index([tag])
}

// 미디어 자산 (SRS-019 · SAD-012). 저장은 StorageProvider(로컬 디스크 기본 · 클라우드 드롭인 ADR-016).
model MediaAsset {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  key         String   @unique // 스토리지 키(파일명)
  url         String // 접근 URL(로컬 서브 라우트 또는 CDN)
  contentType String
  kind        String   @default("image") // image | video(후속)
  bytes       Int
  flagged     Boolean  @default(false) // 자동 스캔 위반 표시(ImageScanner · ADR-016/017)
  flagReason  String?
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

// 스토리 (SRS-019 · SAD-012). 24h 후 만료 — 만료는 조회 시 expiresAt 필터(정리 잡은 후속).
model Story {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mediaUrl  String
  caption   String?
  moderationStatus String @default("approved") // approved|pending|removed (ADR-017)
  removedAt     DateTime?
  removedReason String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([authorId, expiresAt])
  @@index([expiresAt])
}

// DM 대화 (SRS-017 · SAD-011). 1:1 기본(isGroup=false), 그룹은 후속. 실시간 전송은 ADR-015(후속·현재 REST).
model Conversation {
  id           String                    @id @default(uuid())
  isGroup      Boolean                   @default(false)
  directKey    String?                   @unique // 1:1 정규화 키(정렬된 유저쌍) — 동시 생성 시 중복 대화 방지
  title        String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  kind           String       @default("text") // text|image
  body           String?
  mediaUrl       String?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// 좋아요 (SRS-007). 포스트당 사용자 1개.
model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

// 댓글 (SRS-007).
model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  moderationStatus String @default("approved") // approved|removed (ADR-017)
  removedAt DateTime?
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// 알림 (SRS-020). 팔로우·좋아요·댓글 이벤트 fan-out. DM은 unread 배지로 별도.
model Notification {
  id        String    @id @default(uuid())
  userId    String // 수신자
  user      User      @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String // follow | like | comment
  actorId   String // 유발자
  actor     User      @relation("notificationsActor", fields: [actorId], references: [id], onDelete: Cascade)
  postId    String? // like/comment 대상
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

// 신고·모더레이션 (SAD-012 · ADR-017). 사용자 신고 → 모더레이터 큐 → 콘텐츠 소프트 제거.
// 대상은 다형(post|story|comment) — targetType+targetId. 신고자당 대상 1건(멱등).
model Report {
  id          String    @id @default(uuid())
  targetType  String // post | story | comment
  targetId    String
  reporterId  String
  reporter    User      @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reason      String // spam|nudity|harassment|violence|self_harm|minor_safety|misinformation|other
  details     String?
  status      String    @default("pending") // pending | resolved | dismissed
  reviewedBy  String?
  reviewer    User?     @relation("reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt  DateTime?
  actionTaken String? // removed | dismissed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status])
}

// 푸시 알림 디바이스 토큰 (SRS-020 · ADR-015). 발송은 PushProvider(noop 기본·Expo/FCM/WebPush 드롭인).
model PushToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("expo") // expo | web | fcm
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
