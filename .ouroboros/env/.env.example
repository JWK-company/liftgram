# planning-workflow 환경변수 — 복사해서 사용:  cp .env.example .env  후 값 채우기
# ⚠️ .env 는 절대 커밋 금지 (.gitignore 에 포함됨). 토큰 유출 시 즉시 폐기·재발급.

# ── 배포 환경 (섞임 방지 핀) ─────────────────────────────────────────────────
# 이 프로젝트가 붙는 배포 생태계. 설치/갱신 시 setup.sh·update.sh 가 이 값으로 .mcp.json·URL 을
# 원자적으로 맞춘다. 바꾸려면:  PLM_ENV=<env> bash setup.sh  (또는 make setup).
#   jwk     = jwk-*.shoi.ch (k0s)      jungmin = *.jungmin.kim (docker)      custom = 아래 URL 직접
# ★ 한 번 정해지면 update 는 이 환경을 유지한다(다른 배포 URL 과 안 섞임).
PLM_ENV=jwk

# 거버넌스 백엔드 = PLM-Hub. 본문·관계는 로컬 .md SSOT, Status·게이트·추적은 PLM 권위.
# PLM API 쓰기 토큰(token_hash) — hook(셸)이 .md/코드를 PLM 에 자동 upsert 할 때 사용.
# ★ 비워두면 됨: `plm-hub:link` 실행 시 SSO(OIDC) 인증으로 본인 역할 토큰이 자동 발급·기입
#   (POST /tokens 셀프 발급 — realm 역할 없으면 editor). 재발급은 link 재실행 또는 --force.
PLM_API_TOKEN=

# PLM API 엔드포인트(기본 https://jwk-plm.shoi.ch). 프로젝트 바인딩은 `/plm-hub:link <project>` 가
# .ouroboros/config/plm.json 에 기록(project·api_url). 비활성화하려면 PLM_ENABLED=0.
PLM_API_URL=https://jwk-plm.shoi.ch

# ouroboros MCP 정적 공유 토큰 — 헤드리스/채널 세션(브라우저 없음)에서 OAuth 대신 Bearer 인증.
# ★ 채워야 ouro MCP 가 헤드리스에서 붙는다(비우면 .mcp.json headersHelper 가 빈 헤더 → 401).
#   값은 ouro 서버 env `OURO_MCP_TOKEN` 과 동일해야 한다(배포 운영자가 배부). 인증 헤더는
#   .ouroboros/env/mcp-auth.sh 가 이 값을 읽어 생성한다. plm 은 PLM_API_TOKEN 을 같은 방식으로 사용.
#   (브라우저 가능한 대화형이면 이 토큰 없이 /mcp OAuth 로그인도 가능 — .mcp.json 을 oauth 로 되돌릴 것.)
OURO_MCP_TOKEN=

# 선택 — 코드 딥링크 스캔 루트(기본 프로젝트 루트). @plm 주석 → Code 아티팩트.
# PLM_CODE_ROOT=.

# 선택 — PLM 동기 브랜치 고정. 기본은 git 현재 브랜치별로 아티팩트를 격리 동기(SRS-019).
#   git 브랜치가 main 이 아니면(예: master·feature/*) 그 브랜치로 가서 main 뷰에 안 보일 수 있음.
#   아래를 활성화하면 git 브랜치와 무관하게 항상 main 으로 동기 → 대시보드(main)에 일관 표시.
#   (서버 get_doc 은 요청 브랜치에 없으면 main→임의 브랜치로 폴백하므로, 핀 없이도 본문은 보임.)
# PLM_BRANCH=main

# 선택 — 제품명
PLANNING_PRODUCT=MyProduct

# 본문 반출 제외는 아티팩트 CODE.json 래퍼의 `"sync": false` 로 제어(민감 문서).
