          },
          {
            "type": "text",
            "text": "(SetLog 패턴)."
          }
        ]
      },
      {
        "type": "table",
        "content": [
          {
            "type": "table_row",
            "content": [
              {
                "type": "table_header",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "테이블"
