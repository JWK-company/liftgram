                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "grip"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "over/under/neutral/wide/close (방향·폭 향후 분리는 ADR 후보)"
                      }
                    ]
                  }
                ]
              },
              {
