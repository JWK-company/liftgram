                        "text": "컬럼"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_header",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "타입/플래그"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_header",
                "content": [
