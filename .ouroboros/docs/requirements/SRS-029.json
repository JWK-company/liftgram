                      {
                        "type": "text",
                        "text": "의미 / 기본"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "table_row",
            "content": [
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "strict_reps"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "number, optional"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "정자세 반복. null=전부 정자세(=reps). 치팅수 = reps − strict_reps"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "table_row",
            "content": [
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "marks": [
                          {
                            "type": "code"
                          }
                        ],
                        "text": "load_adjust_kg"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "number, optional"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "table_cell",
                "content": [
                  {
                    "type": "paragraph",
                    "content": [
                      {
                        "type": "text",
                        "text": "보정무게(signed). 어시스티드(−)/가중(+). null=0"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "볼륨·PR 순수 계산 계층("
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "volume.ts"
          },
          {
            "type": "text",
            "text": ":8-10, "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "personalRecords.ts"
          },
          {
            "type": "text",
            "text": ":21-29, "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "code"
              }
            ],
            "text": "oneRepMax.ts"
          },
          {
            "type": "text",
            "text": ":7-11)는 유효 반복수와 실효 무게(weightKg + load_adjust_kg, 자중은 체중 반영)를 입력으로 받도록 조정하며, 세트 정밀도는 부모 워크아웃 종목의 변형 버킷(SRS-028/machine_variant)과 직교한다."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "연결"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "도출 URS: URS-016(세트 로깅 정밀도·수행 조건 기록), URS-001(핵심 운동 기록). 설계: SAD-019(수행 기록 데이터 모델). 웰니스 가드레일: SRS-015 준수(정보·기록 보조이며 진단·처방 아님). 경계: 원암/투암(#26) 등 그립·팔 변형은 SRS-028(변형 기반 수행 기록) 소관이며 본 요구는 세트 단위 정밀도(치팅 구분·보정무게)에 한정한다."
          }
        ]
      }
    ]
  }
}